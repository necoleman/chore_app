# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.

# Google Apps Script Web App deployment URL
VITE_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Firebase project config (from Firebase Console → Project Settings → Your apps)
VITE_FCM_API_KEY=
VITE_FCM_AUTH_DOMAIN=
VITE_FCM_PROJECT_ID=
VITE_FCM_STORAGE_BUCKET=
VITE_FCM_MESSAGING_SENDER_ID=
VITE_FCM_APP_ID=

# Firebase Cloud Messaging VAPID key (Firebase Console → Cloud Messaging → Web Push certificates)
VITE_FCM_VAPID_KEY=
